# Backend API URL (default: http://127.0.0.1:8000/api/v1)
VITE_API_URL=http://127.0.0.1:8000/api/v1

# Weather widget defaults (fallback coordinates)
VITE_DEFAULT_LAT=10.8231
VITE_DEFAULT_LNG=106.6297

# Weather API (Open-Meteo)
VITE_WEATHER_API_URL=https://api.open-meteo.com/v1/forecast

# IP Geolocation API for weather fallback (phải hỗ trợ CORS)
VITE_IPAPI_URL=https://ip-api.com/json/
